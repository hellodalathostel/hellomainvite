{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Hello Main",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Check Dist Artifact",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"if (Test-Path dist) { Write-Output 'DIST_OK'; Get-ChildItem dist -Recurse | Select-Object -First 20 FullName } else { Write-Output 'DIST_MISSING'; exit 1 }"
			],
			"isBackground": false
		},
		{
			"label": "Deploy Hosting Live",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb deploy --only hosting"
			],
			"isBackground": false
		},
		{
			"label": "Deploy Hosting Live Retry",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb deploy --only hosting"
			],
			"isBackground": false
		},
		{
			"label": "Deploy Hosting via FirebaseCmd",
			"type": "shell",
			"command": "C:\\Users\\hieun\\AppData\\Roaming\\npm\\firebase.cmd",
			"args": [
				"deploy",
				"--only",
				"hosting"
			],
			"isBackground": false
		},
		{
			"label": "Deploy OTA DB Rules",
			"type": "shell",
			"command": "C:\\Users\\hieun\\AppData\\Roaming\\npm\\firebase.cmd",
			"args": [
				"deploy",
				"--only",
				"database"
			],
			"isBackground": false
		},
		{
			"label": "Build After OTA Update",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Build Latest OTA Changes",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Deploy Live OTA Release",
			"type": "shell",
			"command": "C:\\Users\\hieun\\AppData\\Roaming\\npm\\firebase.cmd",
			"args": [
				"deploy"
			],
			"isBackground": false
		},
		{
			"label": "Prepush Auto Checklist",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".vscode/scripts/prepush-check.ps1"
			],
			"isBackground": false
		},
		{
			"label": "Prepush Auto Checklist (Script)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".vscode/scripts/prepush-check.ps1"
			],
			"isBackground": false
		},
		{
			"label": "dev",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Run Report Tests",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:report"
			],
			"isBackground": false
		},
		{
			"label": "Install Vitest",
			"type": "shell",
			"command": "npm",
			"args": [
				"install",
				"-D",
				"vitest"
			],
			"isBackground": false
		},
		{
			"label": "Run Report Tests After Install",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:report"
			],
			"isBackground": false
		},
		{
			"label": "Run Report Logic Tests",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:report"
			],
			"isBackground": false
		},
		{
			"label": "Uninstall Vitest",
			"type": "shell",
			"command": "npm",
			"args": [
				"uninstall",
				"-D",
				"vitest"
			],
			"isBackground": false
		},
		{
			"label": "Fetch Groups Snapshot",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb database:get /groups --project hello-dalat-manager | Set-Content groups-snapshot.json"
			],
			"isBackground": false
		},
		{
			"label": "Fetch Bookings Snapshot",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb database:get /bookings --project hello-dalat-manager | Set-Content bookings-snapshot.json"
			],
			"isBackground": false
		},
		{
			"label": "Firebase DB Help",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb help database | Set-Content firebase-db-help.txt"
			],
			"isBackground": false
		},
		{
			"label": "Generate Group Repairs",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/repair-legacy-groups.mjs",
				"groups-snapshot.json",
				"bookings-snapshot.json",
				"groups-repair.json"
			],
			"isBackground": false
		},
		{
			"label": "Count Group Repairs",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"(Get-Content groups-repair.json -Raw | ConvertFrom-Json | Get-Member -MemberType NoteProperty).Count"
			],
			"isBackground": false
		},
		{
			"label": "Regenerate Group Repairs",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/repair-legacy-groups.mjs",
				"groups-snapshot.json",
				"bookings-snapshot.json",
				"groups-repair.json"
			],
			"isBackground": false
		},
		{
			"label": "Recount Group Repairs",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"(Get-Content groups-repair.json -Raw | ConvertFrom-Json | Get-Member -MemberType NoteProperty).Count"
			],
			"isBackground": false
		},
		{
			"label": "Apply Group Repairs",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$fb=Join-Path $env:APPDATA 'npm\\firebase.cmd'; & $fb database:update /groups groups-repair.json --project hello-dalat-manager"
			],
			"isBackground": false
		},
		{
			"label": "Predeploy + Rollback Check",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".vscode/scripts/predeploy-rollback-check.ps1"
			],
			"isBackground": false
		}
	]
}