{
  "rules": {
    "bookings": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".indexOn": ["checkIn", "checkOut", "roomId", "createdAt", "phone", "otaBookingNumber", "groupId", "isDeleted"],
      "$bookingId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || (root.child('users').child(auth.uid).child('role').val() === 'staff' && newData.exists() && (data.exists() || !newData.hasChild('paid')) && (!data.exists() || !newData.hasChild('paid') || newData.child('paid').val() === data.child('paid').val()) && newData.child('status').val() !== 'cancelled'))"
      }
    },

    "groups": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      "$groupId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || (root.child('users').child(auth.uid).child('role').val() === 'staff' && newData.exists() && (data.exists() || !newData.child('payment').hasChild('paid')) && (!data.exists() || !newData.child('payment').hasChild('paid') || newData.child('payment/paid').val() === data.child('payment/paid').val()) && newData.child('status').val() !== 'cancelled'))"
      }
    },

    "expenses": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".indexOn": ["date", "isDeleted"],
      "$expenseId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')"
      }
    },

    "audit_logs": {
      ".read": "root.child('users').child(auth.uid).child('role').val() === 'owner'",
      ".indexOn": ["timestamp"],
      "$logId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff') && !data.exists()"
      }
    },

    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'owner'",
        ".write": "root.child('users').child(auth.uid).child('role').val() === 'owner'"
      }
    },

    "rooms": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'owner'"
    },
    "services": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'owner'"
    },
    "app_data": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'owner'"
    },
    "customers": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')"
    },
    "customerUsage": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'staff')"
    }
  }
}
