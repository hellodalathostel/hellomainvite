{
  "name": "hello-main",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "restore:missing-fields": "node scripts/generate-missing-fields-restore.mjs",
    "test": "node --test --test-concurrency=1 --experimental-strip-types \"tests/*.test.ts\"",
    "test:report": "node --test --experimental-strip-types tests/report-analytics.test.ts",
    "prepush:check": "powershell -NoProfile -ExecutionPolicy Bypass -File .vscode/scripts/prepush-check.ps1",
    "preview": "vite preview",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "firebase": "^12.6.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
